# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 依赖目录
node_modules/

# 构建输出
dist/
dist-ssr/
*.local

# 缓存文件
.cache/
.temp/
.tmp/

# 本地环境变量（敏感信息）
.env.local
.env.*.local

# IDE 和编辑器配置
.vscode/
!.vscode/extensions.json    # 保留扩展推荐文件
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?                       # 匹配 .swp, .swo 等
*~
.project
.classpath
.settings/

# 操作系统生成的文件
.DS_Store
Thumbs.db
desktop.ini

# 测试覆盖率报告
coverage/
.nyc_output/

# 依赖管理配置文件（可能包含敏感信息）
.npmrc
.yarnrc
.yarnrc.yml

# 其他可能生成的目录
.output/
.vinfo/
.vite-ssg-dist/